# Server
HOST=0.0.0.0
PORT=3030

# Database (default: data/memory.db)
# MEMORY_DB_PATH=data/memory.db

# Model provider (any OpenAI-compatible endpoint)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# User-local timezone for relative time ("today", "yesterday", "last time")
USER_TIMEZONE=Australia/Sydney

# Embedding model
# Set this explicitly when chat uses a provider without embeddings, such as Anthropic.
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=
# Or set OPENAI_API_KEY_GPT to reuse a separate OpenAI key for embeddings.
EMBEDDING_MODEL=text-embedding-3-small

# Extraction model — cheap model for per-turn profile/memory extraction
# Defaults to OPENAI_MODEL when not set. Use a smaller model to reduce cost.
# EXTRACTION_MODEL=gpt-4.1-nano

# Auth & rate limiting
API_AUTH_TOKEN=
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_MS=60000

# Public hostname (used by Caddy / health checks)
APP_HOSTNAME=memory.example.com
